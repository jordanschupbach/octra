prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
libdir=@CMAKE_INSTALL_FULL_LIBDIR@/@PROJECT_NAME@-@PROJECT_VERSION@
includedir=${prefix}/include/@PROJECT_NAME@-@PROJECT_VERSION@
Name: octra
Description: A C++ library
Version: @PKG_CONFIG_VERSION@
Libs: -L${libdir} @PKG_CONFIG_LIBS@
Cflags: -I${includedir}
