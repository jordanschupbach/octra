# shellcheck shell=bash
if ! has nix_direnv_version || ! nix_direnv_version 3.1.0; then
  source_url 'https://raw.githubusercontent.com/nix-community/nix-direnv/3.1.0/direnvrc' 'sha256-yMJ2OVMzrFaDPn7q8nCBZFRYpL/f0RcHzhmw/i6btJM='
fi
watch_file flake.nix
watch_file nix/octra.nix
watch_file nix/pyoctra.nix
watch_file nix/octrajs.nix
watch_file nix/octratcl.nix
watch_file nix/octruby.nix
watch_file nix/octralua.nix
watch_file nix/octraocaml.nix
watch_file nix/octraguile.nix
watch_file nix/octraoctave.nix
watch_file nix/octrad.nix
use flake path:.
